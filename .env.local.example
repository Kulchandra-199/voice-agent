# Ollama Cloud Configuration
OLLAMA_BASE_URL=https://your-remote-ollama-url
OLLAMA_MODEL=qwen2.5:72b

# Calendar API (pre-deployed Express server)
CALENDAR_API_URL=https://your-calendar-api.railway.app

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/callback
GOOGLE_REFRESH_TOKEN=

# Groq API Key (optional - uses free browser speech if not set)
# Get free key at https://console.groq.com
# If not set, app will use browser's built-in Speech Recognition (free)
GROQ_API_KEY=
NEXT_PUBLIC_GROQ_API_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:4000